# ---------------------------------------------------------------------------
# The Rat Trap — environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- Database ---------------------------------------------------------------
# DATABASE_URL is used by the app at runtime (via the pg driver adapter). For a
# serverless host like Vercel, use a POOLED connection string.
#
# Supabase (pooled, transaction mode — port 6543):
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Local Docker Compose Postgres alternative:
# DATABASE_URL="postgresql://gridiron:gridiron@localhost:5432/gridiron_gazette?schema=public"

# DIRECT_URL is used ONLY by the Prisma CLI for migrations (prisma migrate),
# which need a direct/session connection — a transaction-mode pooler can't run
# DDL or hold advisory locks. Not required by the app runtime, so it does NOT
# need to be set on Vercel.
#
# Supabase (session mode — port 5432):
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres"

# --- Auth (NextAuth / Auth.js v5) -------------------------------------------
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-random-32-byte-base64-string"
# In production set this to your deployed URL, e.g. https://your-app.vercel.app
AUTH_URL="http://localhost:3000"

# --- Sleeper --------------------------------------------------------------
# Leave SLEEPER_LEAGUE_ID unset to run entirely on the built-in mock provider.
SLEEPER_LEAGUE_ID=""
SLEEPER_API_BASE_URL="https://api.sleeper.app/v1"

# --- AI content generation ---------------------------------------------------
# Leave unset to use the built-in MockAIProvider (no network calls, no cost).
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-mini"

# --- Weekly cron -------------------------------------------------------------
# Shared secret protecting /api/cron/weekly. Set the SAME value here and in the
# Vercel project so Vercel Cron's `Authorization: Bearer <CRON_SECRET>` is
# accepted. Leave blank locally to allow manual GETs during development.
CRON_SECRET=""

# --- App -------------------------------------------------------------------
# Default humor level for AI-generated content: 1 (mild) - 5 (full roast).
DEFAULT_HUMOR_LEVEL="3"
