// Gridiron Gazette — Prisma schema
// Prisma 7: generator uses the new unified `prisma-client` output, and the
// datasource connection string is supplied via `prisma.config.ts`, not a
// `url = env(...)` line here. See prisma.config.ts + .env.example.

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Auth / users
// ---------------------------------------------------------------------------

enum UserRole {
  ADMIN
  MEMBER
}

/// A login account. Optionally linked to a Manager so a logged-in league
/// member sees "their" data highlighted. Sessions use NextAuth's JWT
/// strategy, so no Account/Session/VerificationToken tables are needed for
/// the Credentials provider used today.
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  role         UserRole  @default(MEMBER)
  managerId    String?   @unique
  manager      Manager?  @relation(fields: [managerId], references: [id])
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  uploadedChatImports ChatImport[]          @relation("ChatImportUploader")
  reviewedGenerations AIContentGeneration[] @relation("GenerationReviewer")
  triggeredSyncs      DataSyncLog[]         @relation("SyncTrigger")
  authoredArticles    Article[]             @relation("ArticleAuthor")
  predictions         Prediction[]          @relation("PredictionUser")
}

// ---------------------------------------------------------------------------
// League / season structure
// ---------------------------------------------------------------------------

model League {
  id                String   @id @default(cuid())
  name              String
  shortName         String?
  logoUrl           String?
  description       String?
  sleeperLeagueId   String?  @unique
  foundedYear       Int
  defaultHumorLevel Int      @default(3)
  sensitiveTopics   String[] @default([])
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  seasons Season[]
  profile LeagueProfile?
}

enum SeasonStatus {
  UPCOMING
  IN_PROGRESS
  COMPLETE
}

/// Where a season's data came from. Sleeper covers 2023+; pre-2023 history
/// lived on ESPN and is not retrievable from Sleeper's API, so those seasons
/// will be imported from ESPN's leagueHistory endpoint (or entered manually)
/// and tagged accordingly. Stats/records/rivalries read across all sources.
enum SeasonDataSource {
  SLEEPER
  ESPN
  MANUAL
}

model Season {
  id                      String           @id @default(cuid())
  leagueId                String
  league                  League           @relation(fields: [leagueId], references: [id])
  year                    Int
  dataSource              SeasonDataSource @default(SLEEPER)
  sleeperLeagueId         String?          @unique
  previousSleeperLeagueId String?
  /// ESPN league id for ESPN-sourced seasons (null for Sleeper seasons).
  espnLeagueId            String?
  status                  SeasonStatus     @default(UPCOMING)
  regularSeasonWeeks      Int              @default(14)
  playoffTeams            Int              @default(6)
  playoffStartWeek        Int              @default(15)
  isCurrent               Boolean          @default(false)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt

  fantasyTeams      FantasyTeam[]
  matchups          Matchup[]
  drafts            Draft[]
  transactions      Transaction[]
  standingSnapshots StandingSnapshot[]
  championship      Championship?
  articles          Article[]
  awards            Award[]
  leagueRecords     LeagueRecord[]
  historicalQuotes  HistoricalQuote[]
  dataSyncLogs      DataSyncLog[]
  punishments       Punishment[]
  predictions       Prediction[]
  draftGrades       DraftGrade[]
  weeklyAwards      WeeklyAward[]
  receipts          Receipt[]
  historySections   LeagueHistorySection[]

  @@unique([leagueId, year])
}

// ---------------------------------------------------------------------------
// Managers and teams
// ---------------------------------------------------------------------------

/// A person, persistent across seasons even as their Sleeper team/roster
/// IDs and team names change.
model Manager {
  id             String    @id @default(cuid())
  displayName    String
  sleeperUserId  String?   @unique
  avatarUrl      String?
  bio            String?
  /// Uploaded face photo (separate from the Sleeper avatar). URL or /public path.
  photoUrl       String?
  /// Personality layer (admin-editable).
  nickname       String?
  nicknameOrigin String?
  signatureMove  String?
  joinedYear     Int
  isActive       Boolean   @default(true)
  /// Per-manager AI-safeguard opt-out (spec: "per-manager no-roast settings").
  noRoast        Boolean   @default(false)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  user               User?
  fantasyTeams       FantasyTeam[]
  teamNameHistory    TeamNameHistory[]
  draftPicks         DraftPick[]
  transactionAssets  TransactionAsset[]
  championships      Championship[]
  awards             Award[]
  historicalQuotes   HistoricalQuote[]
  chatParticipants   ChatParticipant[]
  chatMessages       ChatMessage[]              @relation("ChatMessageLinkedManager")
  articleSections    ArticleSection[]
  rivalriesAsA       Rivalry[]                  @relation("RivalryManagerA")
  rivalriesAsB       Rivalry[]                  @relation("RivalryManagerB")
  leagueRecords      LeagueRecord[]
  punishments        Punishment[]
  predictionsMade    Prediction[]               @relation("PredictionAuthor")
  draftGrades        DraftGrade[]
  weeklyAwards       WeeklyAward[]
  chatIdentityMaps   ChatIdentityMap[]          @relation("ChatIdentityManager")
  aliases            ManagerAlias[]
  historySections    LeagueHistorySection[]
  knowledgeLinks     LeagueKnowledgeManager[]
  mediaAssets        MediaAsset[]
  performanceSummary ManagerPerformanceSummary?
  commProfile        ManagerCommunicationProfile?
  relationshipsAsA   ManagerRelationship[]      @relation("RelationshipManagerA")
  relationshipsAsB   ManagerRelationship[]      @relation("RelationshipManagerB")
}

/// A manager's team for one specific season (Sleeper roster).
model FantasyTeam {
  id                String   @id @default(cuid())
  seasonId          String
  season            Season   @relation(fields: [seasonId], references: [id])
  managerId         String
  manager           Manager  @relation(fields: [managerId], references: [id])
  sleeperRosterId   String?
  teamName          String
  logoUrl           String?
  wins              Int      @default(0)
  losses            Int      @default(0)
  ties              Int      @default(0)
  pointsFor         Float    @default(0)
  pointsAgainst     Float    @default(0)
  regularSeasonRank Int?
  finalRank         Int?
  madePlayoffs      Boolean  @default(false)
  playoffSeed       Int?
  isChampion        Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  teamNameHistory       TeamNameHistory[]
  rosters               Roster[]
  matchupTeams          MatchupTeam[]
  standingSnapshots     StandingSnapshot[]
  draftPicksOwned       DraftPick[]        @relation("DraftPickCurrentOwner")
  draftPicksOriginal    DraftPick[]        @relation("DraftPickOriginalOwner")
  transactionAssets     TransactionAsset[]
  championshipsWon      Championship[]     @relation("ChampionshipWinner")
  championshipsRunnerUp Championship[]     @relation("ChampionshipRunnerUp")
  championshipsThird    Championship[]     @relation("ChampionshipThird")
  awards                Award[]

  @@unique([seasonId, managerId])
}

model TeamNameHistory {
  id            String       @id @default(cuid())
  managerId     String
  manager       Manager      @relation(fields: [managerId], references: [id])
  fantasyTeamId String?
  fantasyTeam   FantasyTeam? @relation(fields: [fantasyTeamId], references: [id])
  name          String
  seasonYear    Int
  startDate     DateTime     @default(now())
  endDate       DateTime?
  createdAt     DateTime     @default(now())
}

// ---------------------------------------------------------------------------
// Players and rosters
// ---------------------------------------------------------------------------

model FantasyPlayer {
  id              String   @id @default(cuid())
  sleeperPlayerId String?  @unique
  firstName       String
  lastName        String
  position        String
  nflTeam         String?
  status          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  weeklyScores      WeeklyPlayerScore[]
  draftPicks        DraftPick[]
  transactionAssets TransactionAsset[]
  chatMessages      ChatMessage[]

  @@index([lastName, firstName])
}

/// One row per fantasy team per week — the starting-lineup/bench header for
/// that week. Re-syncing a week updates that week's row only; other weeks
/// are untouched, which is how weekly history is preserved.
model Roster {
  id              String      @id @default(cuid())
  fantasyTeamId   String
  fantasyTeam     FantasyTeam @relation(fields: [fantasyTeamId], references: [id])
  week            Int
  sleeperRosterId String?
  syncedAt        DateTime    @default(now())
  createdAt       DateTime    @default(now())

  playerScores WeeklyPlayerScore[]

  @@unique([fantasyTeamId, week])
}

model WeeklyPlayerScore {
  id              String        @id @default(cuid())
  rosterId        String
  roster          Roster        @relation(fields: [rosterId], references: [id])
  playerId        String
  player          FantasyPlayer @relation(fields: [playerId], references: [id])
  lineupSlot      String
  isStarter       Boolean       @default(false)
  points          Float         @default(0)
  projectedPoints Float?
  createdAt       DateTime      @default(now())

  @@unique([rosterId, playerId])
  @@index([playerId])
}

// ---------------------------------------------------------------------------
// Matchups and standings
// ---------------------------------------------------------------------------

enum MatchupStatus {
  SCHEDULED
  IN_PROGRESS
  FINAL
}

enum BracketType {
  WINNERS
  CONSOLATION
}

model Matchup {
  id               String        @id @default(cuid())
  seasonId         String
  season           Season        @relation(fields: [seasonId], references: [id])
  week             Int
  sleeperMatchupId String?
  isPlayoff        Boolean       @default(false)
  playoffRound     Int?
  bracketType      BracketType?
  roundName        String?
  status           MatchupStatus @default(SCHEDULED)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  teams MatchupTeam[]

  @@index([seasonId, week])
}

model MatchupTeam {
  id             String      @id @default(cuid())
  matchupId      String
  matchup        Matchup     @relation(fields: [matchupId], references: [id])
  fantasyTeamId  String
  fantasyTeam    FantasyTeam @relation(fields: [fantasyTeamId], references: [id])
  score          Float?
  projectedScore Float?
  benchPoints    Float?
  isWinner       Boolean?
  createdAt      DateTime    @default(now())

  @@unique([matchupId, fantasyTeamId])
  @@index([fantasyTeamId])
}

/// Insert-only, point-in-time standings row captured on every sync. Never
/// updated after the fact, so `/history/[season]` can chart the week-by-week
/// standings progression exactly as it looked at the time.
model StandingSnapshot {
  id            String      @id @default(cuid())
  seasonId      String
  season        Season      @relation(fields: [seasonId], references: [id])
  fantasyTeamId String
  fantasyTeam   FantasyTeam @relation(fields: [fantasyTeamId], references: [id])
  week          Int
  wins          Int
  losses        Int
  ties          Int
  pointsFor     Float
  pointsAgainst Float
  rank          Int
  streak        String?
  capturedAt    DateTime    @default(now())

  @@index([seasonId, week])
  @@index([fantasyTeamId])
}

// ---------------------------------------------------------------------------
// Drafts
// ---------------------------------------------------------------------------

enum DraftType {
  SNAKE
  AUCTION
  LINEAR
}

model Draft {
  id             String    @id @default(cuid())
  seasonId       String
  season         Season    @relation(fields: [seasonId], references: [id])
  sleeperDraftId String?
  type           DraftType @default(SNAKE)
  rounds         Int
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  picks DraftPick[]

  @@unique([seasonId])
}

model DraftPick {
  id                    String         @id @default(cuid())
  draftId               String
  draft                 Draft          @relation(fields: [draftId], references: [id])
  round                 Int
  pickNumber            Int
  draftSlot             Int
  originalFantasyTeamId String
  originalFantasyTeam   FantasyTeam    @relation("DraftPickOriginalOwner", fields: [originalFantasyTeamId], references: [id])
  fantasyTeamId         String
  fantasyTeam           FantasyTeam    @relation("DraftPickCurrentOwner", fields: [fantasyTeamId], references: [id])
  managerId             String?
  manager               Manager?       @relation(fields: [managerId], references: [id])
  playerId              String?
  player                FantasyPlayer? @relation(fields: [playerId], references: [id])
  isKeeper              Boolean        @default(false)
  auctionAmount         Float?
  createdAt             DateTime       @default(now())

  @@unique([draftId, pickNumber])
  @@index([playerId])
}

// ---------------------------------------------------------------------------
// Transactions and trades
// ---------------------------------------------------------------------------

enum TransactionType {
  WAIVER
  FREE_AGENT
  TRADE
  COMMISSIONER
}

enum TransactionStatus {
  PENDING
  COMPLETE
  FAILED
  REVERSED
}

model Transaction {
  id                   String            @id @default(cuid())
  seasonId             String
  season               Season            @relation(fields: [seasonId], references: [id])
  week                 Int?
  sleeperTransactionId String?
  type                 TransactionType
  status               TransactionStatus @default(COMPLETE)
  faabSpent            Int?
  processedAt          DateTime          @default(now())
  createdAt            DateTime          @default(now())

  assets TransactionAsset[]
  trade  Trade?

  @@index([seasonId, week])
  @@index([type])
}

enum AssetDirection {
  ADD
  DROP
}

enum AssetType {
  PLAYER
  DRAFT_PICK
  FAAB
}

model TransactionAsset {
  id                   String         @id @default(cuid())
  transactionId        String
  transaction          Transaction    @relation(fields: [transactionId], references: [id])
  fantasyTeamId        String
  fantasyTeam          FantasyTeam    @relation(fields: [fantasyTeamId], references: [id])
  managerId            String?
  manager              Manager?       @relation(fields: [managerId], references: [id])
  direction            AssetDirection
  assetType            AssetType
  playerId             String?
  player               FantasyPlayer? @relation(fields: [playerId], references: [id])
  draftPickDescription String?
  faabAmount           Int?
  createdAt            DateTime       @default(now())

  @@index([playerId])
}

/// Trade-specific extension of a Transaction (type = TRADE).
model Trade {
  id            String      @id @default(cuid())
  transactionId String      @unique
  transaction   Transaction @relation(fields: [transactionId], references: [id])
  isNotable     Boolean     @default(false)
  notes         String?
  createdAt     DateTime    @default(now())
}

// ---------------------------------------------------------------------------
// Playoffs, championships, records, rivalries
// ---------------------------------------------------------------------------

model PlayoffBracket {
  id          String      @id @default(cuid())
  seasonId    String
  round       Int
  bracketType BracketType
  roundName   String
  matchupId   String?     @unique
  createdAt   DateTime    @default(now())

  @@index([seasonId, round])
}

model Championship {
  id                      String       @id @default(cuid())
  seasonId                String       @unique
  season                  Season       @relation(fields: [seasonId], references: [id])
  championFantasyTeamId   String
  championFantasyTeam     FantasyTeam  @relation("ChampionshipWinner", fields: [championFantasyTeamId], references: [id])
  championManagerId       String
  championManager         Manager      @relation(fields: [championManagerId], references: [id])
  runnerUpFantasyTeamId   String?
  runnerUpFantasyTeam     FantasyTeam? @relation("ChampionshipRunnerUp", fields: [runnerUpFantasyTeamId], references: [id])
  thirdPlaceFantasyTeamId String?
  thirdPlaceFantasyTeam   FantasyTeam? @relation("ChampionshipThird", fields: [thirdPlaceFantasyTeamId], references: [id])
  /// Editable victory speech shown on the Championship Belt page.
  victorySpeech           String?
  createdAt               DateTime     @default(now())
}

/// Manually-recorded last-place punishment for a season (Hall of Shame).
/// Admin-editable; the photo slot is a URL (upload later, or /public path).
model Punishment {
  id          String   @id @default(cuid())
  seasonId    String?
  season      Season?  @relation(fields: [seasonId], references: [id])
  year        Int
  managerId   String?
  manager     Manager? @relation(fields: [managerId], references: [id])
  description String
  photoUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([year])
}

enum RecordCategory {
  HIGHEST_WEEKLY_SCORE
  LOWEST_WEEKLY_SCORE
  LARGEST_BLOWOUT
  CLOSEST_GAME
  HIGHEST_SCORE_IN_LOSS
  LOWEST_SCORE_IN_WIN
  MOST_BENCH_POINTS
  MOST_CHAMPIONSHIPS
  MOST_PLAYOFF_APPEARANCES
  LONGEST_WIN_STREAK
  LONGEST_LOSS_STREAK
  MOST_POINTS_SEASON
  BEST_LINEUP_EFFICIENCY
  WORST_LINEUP_EFFICIENCY
}

/// A record holder for one category. Old holders are kept (supersededAt set)
/// rather than deleted, so `/records` can show "record history" later.
model LeagueRecord {
  id           String         @id @default(cuid())
  seasonId     String?
  season       Season?        @relation(fields: [seasonId], references: [id])
  category     RecordCategory
  value        Float
  managerId    String?
  manager      Manager?       @relation(fields: [managerId], references: [id])
  week         Int?
  description  String
  supersededAt DateTime?
  recordedAt   DateTime       @default(now())

  @@index([category])
}

model Rivalry {
  id                     String    @id @default(cuid())
  managerAId             String
  managerA               Manager   @relation("RivalryManagerA", fields: [managerAId], references: [id])
  managerBId             String
  managerB               Manager   @relation("RivalryManagerB", fields: [managerBId], references: [id])
  gamesPlayed            Int       @default(0)
  managerAWins           Int       @default(0)
  managerBWins           Int       @default(0)
  ties                   Int       @default(0)
  playoffMeetings        Int       @default(0)
  closestGameMargin      Float?
  largestBlowoutMargin   Float?
  currentStreakManagerId String?
  currentStreakCount     Int       @default(0)
  rivalryScore           Float     @default(0)
  lastMeetingAt          DateTime?
  updatedAt              DateTime  @updatedAt
  createdAt              DateTime  @default(now())

  @@unique([managerAId, managerBId])
}

// ---------------------------------------------------------------------------
// AI-generated content: articles / newspaper
// ---------------------------------------------------------------------------

enum ArticleType {
  WEEKLY_ISSUE
  MATCHUP_PREVIEW
  MATCHUP_RECAP
  SEASON_SUMMARY
  MANAGER_PROFILE
  TRADE_RETROSPECTIVE
}

enum ArticleStatus {
  DRAFT
  PENDING_REVIEW
  PUBLISHED
  ARCHIVED
}

model Article {
  id           String        @id @default(cuid())
  seasonId     String
  season       Season        @relation(fields: [seasonId], references: [id])
  week         Int?
  type         ArticleType
  title        String
  slug         String
  status       ArticleStatus @default(DRAFT)
  heroImageUrl String?
  authorUserId String?
  authorUser   User?         @relation("ArticleAuthor", fields: [authorUserId], references: [id])
  publishedAt  DateTime?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?

  sections    ArticleSection[]
  generations AIContentGeneration[]

  @@unique([seasonId, slug])
  @@index([seasonId, week])
}

enum ArticleSectionType {
  INTRO
  MATCHUP_RECAP
  POWER_RANKINGS
  MANAGER_OF_WEEK
  WORST_DECISION
  BAD_BEAT
  FRAUD_WIN
  QUOTE_OF_WEEK
  WAIVER_REPORT
  PREVIEW
  GENERIC
}

model ArticleSection {
  id               String             @id @default(cuid())
  articleId        String
  article          Article            @relation(fields: [articleId], references: [id])
  order            Int
  sectionType      ArticleSectionType @default(GENERIC)
  heading          String?
  body             String
  relatedManagerId String?
  relatedManager   Manager?           @relation(fields: [relatedManagerId], references: [id])
  createdAt        DateTime           @default(now())

  @@index([articleId, order])
}

enum AwardType {
  MANAGER_OF_WEEK
  WORST_DECISION_OF_WEEK
  BAD_BEAT
  FRAUD_WIN
  CHAMPION
  RUNNER_UP
  MOST_POINTS_SEASON
  BEST_WAIVER_PICKUP
  BIGGEST_TRADE
}

model Award {
  id            String       @id @default(cuid())
  seasonId      String
  season        Season       @relation(fields: [seasonId], references: [id])
  week          Int?
  type          AwardType
  managerId     String
  manager       Manager      @relation(fields: [managerId], references: [id])
  fantasyTeamId String?
  fantasyTeam   FantasyTeam? @relation(fields: [fantasyTeamId], references: [id])
  description   String
  createdAt     DateTime     @default(now())

  @@index([seasonId, week])
}

// ---------------------------------------------------------------------------
// AI content generation log (provider-agnostic)
// ---------------------------------------------------------------------------

enum AIGenerationStatus {
  GENERATED
  APPROVED
  REJECTED
  EDITED
}

/// Every AI call is logged here — structured input summary (not raw DB
/// dumps or chat archives), provider/model, prompt version, and full output
/// — so generations can be reviewed, regenerated, or edited before
/// publishing. See src/server/ai/ for the provider interface.
model AIContentGeneration {
  id               String             @id @default(cuid())
  contentType      ArticleType
  relatedArticleId String?
  relatedArticle   Article?           @relation(fields: [relatedArticleId], references: [id])
  promptVersion    String
  humorLevel       Int
  providerName     String
  model            String
  inputSummary     Json
  outputText       String
  status           AIGenerationStatus @default(GENERATED)
  generatedAt      DateTime           @default(now())
  reviewedByUserId String?
  reviewedByUser   User?              @relation("GenerationReviewer", fields: [reviewedByUserId], references: [id])
  reviewedAt       DateTime?

  @@index([contentType])
}

// ---------------------------------------------------------------------------
// Group-chat lore ingestion (provider-agnostic parser architecture)
// ---------------------------------------------------------------------------

enum ChatPlatform {
  IMESSAGE
  WHATSAPP
  GROUPME
  DISCORD
  PLAIN_TEXT
  CSV
  JSON
}

enum ChatImportStatus {
  UPLOADED
  PARSING
  PARSED
  FAILED
  APPROVED
}

model ChatImport {
  id               String           @id @default(cuid())
  uploadedByUserId String
  uploadedByUser   User             @relation("ChatImportUploader", fields: [uploadedByUserId], references: [id])
  sourcePlatform   ChatPlatform
  originalFileName String
  fileSizeBytes    Int
  status           ChatImportStatus @default(UPLOADED)
  messageCount     Int?
  errorMessage     String?
  createdAt        DateTime         @default(now())
  completedAt      DateTime?

  participants ChatParticipant[]
  messages     ChatMessage[]
}

model ChatParticipant {
  id              String     @id @default(cuid())
  chatImportId    String
  chatImport      ChatImport @relation(fields: [chatImportId], references: [id])
  rawIdentifier   String
  linkedManagerId String?
  linkedManager   Manager?   @relation(fields: [linkedManagerId], references: [id])
  isExcluded      Boolean    @default(false)
  createdAt       DateTime   @default(now())

  messages ChatMessage[]

  @@unique([chatImportId, rawIdentifier])
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum SensitivityStatus {
  NONE
  SENSITIVE
  REDACTED
}

/// Canonical parsed-message shape shared by every platform parser
/// (see src/server/chat-import/providers/). Only APPROVED, non-REDACTED
/// messages are ever eligible to be retrieved as AI context.
model ChatMessage {
  id                String            @id @default(cuid())
  chatImportId      String
  chatImport        ChatImport        @relation(fields: [chatImportId], references: [id])
  participantId     String
  participant       ChatParticipant   @relation(fields: [participantId], references: [id])
  timestamp         DateTime
  text              String?
  hasAttachment     Boolean           @default(false)
  attachmentsMeta   Json?
  replyToMessageId  String?
  replyToMessage    ChatMessage?      @relation("ChatMessageReply", fields: [replyToMessageId], references: [id])
  replies           ChatMessage[]     @relation("ChatMessageReply")
  sourcePlatform    ChatPlatform
  approvalStatus    ApprovalStatus    @default(PENDING)
  sensitivityStatus SensitivityStatus @default(NONE)
  linkedManagerId   String?
  linkedManager     Manager?          @relation("ChatMessageLinkedManager", fields: [linkedManagerId], references: [id])
  linkedSeasonYear  Int?
  linkedWeek        Int?
  linkedMatchupId   String?
  linkedPlayerId    String?
  linkedPlayer      FantasyPlayer?    @relation(fields: [linkedPlayerId], references: [id])
  /// PDF/bulk-import provenance (spec: preserve page number + parse confidence).
  sourcePage        Int?
  rawSender         String?
  normalizedSender  String?
  parseConfidence   Float?
  createdAt         DateTime          @default(now())
  deletedAt         DateTime?

  tags              ChatTag[]
  quotes            HistoricalQuote[]
  receipts          Receipt[]
  knowledgeEvidence KnowledgeEvidence[]

  @@index([chatImportId])
  @@index([participantId])
  @@index([approvalStatus, sensitivityStatus])
  @@index([sourcePage])
}

model ChatTag {
  id        String      @id @default(cuid())
  messageId String
  message   ChatMessage @relation(fields: [messageId], references: [id])
  tag       String
  createdAt DateTime    @default(now())

  @@unique([messageId, tag])
}

model HistoricalQuote {
  id              String         @id @default(cuid())
  text            String
  managerId       String?
  manager         Manager?       @relation(fields: [managerId], references: [id])
  sourceMessageId String?
  sourceMessage   ChatMessage?   @relation(fields: [sourceMessageId], references: [id])
  seasonId        String?
  season          Season?        @relation(fields: [seasonId], references: [id])
  week            Int?
  context         String?
  isFeatured      Boolean        @default(false)
  approvalStatus  ApprovalStatus @default(PENDING)
  createdAt       DateTime       @default(now())
}

// ---------------------------------------------------------------------------
// Sync / audit log
// ---------------------------------------------------------------------------

enum SyncType {
  FULL_LEAGUE
  SEASON
  WEEK
  TRANSACTIONS
  DRAFT
  STATS_RECALC
}

enum SyncStatus {
  RUNNING
  SUCCESS
  FAILED
  PARTIAL
}

model DataSyncLog {
  id                String     @id @default(cuid())
  syncType          SyncType
  seasonId          String?
  season            Season?    @relation(fields: [seasonId], references: [id])
  week              Int?
  status            SyncStatus @default(RUNNING)
  recordsProcessed  Int?
  errorMessage      String?
  triggeredByUserId String?
  triggeredByUser   User?      @relation("SyncTrigger", fields: [triggeredByUserId], references: [id])
  startedAt         DateTime   @default(now())
  finishedAt        DateTime?

  @@index([syncType, status])
}

// ---------------------------------------------------------------------------
// Feature-expansion models
// ---------------------------------------------------------------------------

/// A signed-in manager's preseason predictions for a season. Locks at a
/// deadline; accuracy is scored live and at season end (Prophet Rating).
model Prediction {
  id                         String   @id @default(cuid())
  seasonId                   String
  season                     Season   @relation(fields: [seasonId], references: [id])
  userId                     String?
  user                       User?    @relation("PredictionUser", fields: [userId], references: [id])
  /// The manager this prediction is FOR/BY (predictions are per manager).
  managerId                  String
  manager                    Manager  @relation("PredictionAuthor", fields: [managerId], references: [id])
  /// Ordered array of predicted final-standings managerIds (1st..last).
  predictedStandings         Json
  predictedChampionManagerId String?
  predictedLastManagerId     String?
  predictedOwnWins           Int?
  predictedOwnLosses         Int?
  bustManagerId              String?
  boldTake                   String?
  /// True once the deadline has passed and this can no longer be edited.
  locked                     Boolean  @default(false)
  submittedAt                DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@unique([seasonId, managerId])
}

enum GradeLetter {
  A_PLUS
  A
  A_MINUS
  B_PLUS
  B
  B_MINUS
  C_PLUS
  C
  C_MINUS
  D
  F
}

/// AI draft grade for one manager in one season, plus an optional "revisited"
/// grade computed after the season completes (original vs. actual outcome).
model DraftGrade {
  id                 String       @id @default(cuid())
  seasonId           String
  season             Season       @relation(fields: [seasonId], references: [id])
  managerId          String
  manager            Manager      @relation(fields: [managerId], references: [id])
  grade              GradeLetter?
  rationale          String?
  revisitedGrade     GradeLetter?
  revisitedRationale String?
  providerName       String?
  generatedAt        DateTime     @default(now())
  revisitedAt        DateTime?

  @@unique([seasonId, managerId])
}

enum WeeklyAwardType {
  BOOM_OF_WEEK
  BUST_OF_WEEK
  BENCH_BLUNDER
  LUCKIEST_WIN
  UNLUCKIEST_LOSS
}

/// A computed weekly award for a manager (booms, busts, luck). Distinct from
/// the AI-narrative Award model — these are deterministic, tallied per season.
model WeeklyAward {
  id          String          @id @default(cuid())
  seasonId    String
  season      Season          @relation(fields: [seasonId], references: [id])
  week        Int
  type        WeeklyAwardType
  managerId   String
  manager     Manager         @relation(fields: [managerId], references: [id])
  value       Float?
  description String
  createdAt   DateTime        @default(now())

  @@unique([seasonId, week, type])
  @@index([managerId])
}

/// A curated "receipt": a chat message flagged as a bold take, paired with what
/// actually happened, with an AI verdict. Goes through review/approve before
/// publishing. Reuses ApprovalStatus.
model Receipt {
  id             String         @id @default(cuid())
  chatMessageId  String?
  chatMessage    ChatMessage?   @relation(fields: [chatMessageId], references: [id])
  seasonId       String?
  season         Season?        @relation(fields: [seasonId], references: [id])
  takeText       String
  outcomeText    String?
  verdict        String?
  isWorstTake    Boolean        @default(false)
  approvalStatus ApprovalStatus @default(PENDING)
  createdAt      DateTime       @default(now())
}

/// Remembered mapping from a raw chat handle / phone number to a Manager, so
/// repeated bulk imports don't need re-mapping. Reused across ChatImports.
model ChatIdentityMap {
  id            String   @id @default(cuid())
  rawIdentifier String   @unique
  managerId     String?
  manager       Manager? @relation("ChatIdentityManager", fields: [managerId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Identity resolution, league lore, media, and content-usage tracking
// (source-import / knowledge-base expansion — see scripts/chat-import/ and
// src/server/lore/). Everything here defaults to admin-only until approved.
// ---------------------------------------------------------------------------

enum AliasType {
  FULL_NAME
  FIRST_NAME
  SLEEPER_USERNAME
  TEAM_NAME
  NICKNAME
  PHONE
  EMAIL
  OTHER
}

/// A known alias for a manager (full name, first name, team name, phone, etc.).
/// Used to resolve chat senders and search. ChatIdentityMap handles the
/// canonical raw-handle->manager mapping for imports; this is the richer,
/// human-facing alias set.
model ManagerAlias {
  id         String    @id @default(cuid())
  managerId  String
  manager    Manager   @relation(fields: [managerId], references: [id])
  aliasType  AliasType
  value      String
  source     String?
  confidence Float     @default(1)
  createdAt  DateTime  @default(now())

  @@unique([managerId, aliasType, value])
  @@index([aliasType, value])
}

enum HistorySectionType {
  ORIGIN
  SEASON_SUMMARY
  CHAMPIONSHIP
  RIVALRY
  RULE_CHANGE
  CONTROVERSY
  DRAFT_EVENT
  TRADE
  PUNISHMENT
  TEAM_NAME_CHANGE
  MEMORABLE_MOMENT
  OTHER
}

/// A structured slice of the commissioner's written league history. Preserves
/// the original text (body) and its source (sourceRef). Verified Sleeper stats
/// always take precedence over narrative claims; ambiguous items stay PENDING.
model LeagueHistorySection {
  id             String             @id @default(cuid())
  year           Int?
  seasonId       String?
  season         Season?            @relation(fields: [seasonId], references: [id])
  sectionType    HistorySectionType @default(SEASON_SUMMARY)
  title          String
  body           String
  sourceRef      String?
  managerId      String?
  manager        Manager?           @relation(fields: [managerId], references: [id])
  approvalStatus ApprovalStatus     @default(PENDING)
  sensitivity    SensitivityStatus  @default(NONE)
  sortOrder      Int                @default(0)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  @@index([year])
  @@index([approvalStatus])
}

enum KnowledgeType {
  PERSONALITY_TRAIT
  DRAFT_TENDENCY
  TRADE_TENDENCY
  WAIVER_TENDENCY
  RIVALRY
  INSIDE_JOKE
  NICKNAME
  QUOTE
  FAILED_PREDICTION
  MEMORABLE_MOMENT
  PLAYOFF_COLLAPSE
  DRAFT_DISASTER
  TRADE_REGRET
  CHAMPIONSHIP_STORY
  PUNISHMENT
  TRADITION
  STORYLINE
}

enum PrivacyStatus {
  PUBLIC_SAFE
  PRIVATE
  NEVER_PUBLISH
}

/// A distilled piece of league knowledge (trait, rivalry, joke, quote, event)
/// proposed from chat/history evidence. Only APPROVED + PUBLIC_SAFE records may
/// ever feed public AI content. Prefer repeated patterns over single messages —
/// every record carries supporting evidence + a confidence score.
model LeagueKnowledge {
  id             String            @id @default(cuid())
  knowledgeType  KnowledgeType
  title          String
  body           String
  seasonYear     Int?
  confidence     Float             @default(0.5)
  approvalStatus ApprovalStatus    @default(PENDING)
  sensitivity    SensitivityStatus @default(NONE)
  privacyStatus  PrivacyStatus     @default(PRIVATE)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  managers      LeagueKnowledgeManager[]
  evidence      KnowledgeEvidence[]
  contentUsages ContentUsage[]

  @@index([knowledgeType, approvalStatus])
  @@index([approvalStatus, privacyStatus])
}

/// Join: which managers a knowledge record is about.
model LeagueKnowledgeManager {
  knowledgeId String
  knowledge   LeagueKnowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  managerId   String
  manager     Manager         @relation(fields: [managerId], references: [id])

  @@id([knowledgeId, managerId])
  @@index([managerId])
}

/// A supporting message (or note) backing a knowledge record. Message IDs let
/// admins "view source evidence" and let the AI cite where a claim came from.
model KnowledgeEvidence {
  id            String          @id @default(cuid())
  knowledgeId   String
  knowledge     LeagueKnowledge @relation(fields: [knowledgeId], references: [id], onDelete: Cascade)
  chatMessageId String?
  chatMessage   ChatMessage?    @relation(fields: [chatMessageId], references: [id])
  seasonYear    Int?
  note          String?
  createdAt     DateTime        @default(now())

  @@index([knowledgeId])
}

enum MediaCategory {
  PROFILE
  HOMEPAGE_HERO
  HISTORY
  CHAMPIONSHIP
  DRAFT
  LOGIN
  BACKGROUND
  EVENT
  UNCERTAIN
}

/// An uploaded image (profile pic, league photo, event graphic) with a
/// suggested category. Images showing identifiable people or of unclear
/// purpose stay PENDING/UNCERTAIN and are never shown publicly until an admin
/// approves + publishes them for a specific category.
model MediaAsset {
  id               String         @id @default(cuid())
  kind             String         @default("image")
  originalFilename String
  url              String
  width            Int?
  height           Int?
  fileSizeBytes    Int?
  category         MediaCategory  @default(UNCERTAIN)
  managerId        String?
  manager          Manager?       @relation(fields: [managerId], references: [id])
  approvalStatus   ApprovalStatus @default(PENDING)
  isPublished      Boolean        @default(false)
  sortOrder        Int            @default(0)
  notes            String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([category, isPublished])
  @@index([approvalStatus])
}

/// Records which knowledge records / verified facts a given AI generation used,
/// so the writer can avoid repeating the same jokes and material across content.
model ContentUsage {
  id           String           @id @default(cuid())
  generationId String?
  knowledgeId  String?
  knowledge    LeagueKnowledge? @relation(fields: [knowledgeId], references: [id])
  factKey      String?
  articleType  String?
  createdAt    DateTime         @default(now())

  @@index([generationId])
  @@index([knowledgeId])
}

/// A saved, verified manager-performance summary (career stats + commissioner
/// history + approved personality knowledge), generated once and reused. Admins
/// can regenerate. Distinct from the AI scouting report (transactions/draft).
model ManagerPerformanceSummary {
  id           String   @id @default(cuid())
  managerId    String   @unique
  manager      Manager  @relation(fields: [managerId], references: [id])
  summary      String
  providerName String?
  isMock       Boolean  @default(false)
  inputHash    String?
  generatedAt  DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Chat-archive consolidation: private personality/communication profiles,
// league-wide voice profile, and manager-to-manager relationship summaries.
// All admin-only/PRIVATE by default — synthesized from the group-chat archive
// and used only as tone/voice research packets for AI generation. There is NO
// public page, quote library, or searchable message archive over these.
// ---------------------------------------------------------------------------

/// A private, admin-only personality + communication profile for one manager,
/// distilled from their messages across the whole archive (tone, humor style,
/// verbal tics, recurring themes, how they trash-talk/argue). Never shown
/// publicly; feeds AI research packets so generated copy sounds like the league.
/// Generate-once-reuse; regenerable when new material is imported.
model ManagerCommunicationProfile {
  id                 String   @id @default(cuid())
  managerId          String   @unique
  manager            Manager  @relation(fields: [managerId], references: [id])
  /// Full narrative profile (plain text).
  profile            String
  /// One-line communication-style tagline (e.g. "dry, meme-heavy, quick to needle").
  styleSummary       String?
  /// Structured facets the writer can pull (tone, humorStyle, catchphrases, topics).
  facets             Json?
  /// How many of the manager's messages informed this profile.
  messagesConsidered Int      @default(0)
  providerName       String?
  model              String?
  isMock             Boolean  @default(false)
  inputHash          String?
  generatedAt        DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

/// Singleton (one row per league), admin-only league-wide voice profile:
/// overall humor + communication style, group dynamics, traditions, and useful
/// historical context distilled from the whole archive + commissioner history.
/// Feeds every AI generation as tone/voice guidance.
model LeagueProfile {
  id                 String   @id @default(cuid())
  leagueId           String   @unique
  league             League   @relation(fields: [leagueId], references: [id])
  humorStyle         String?
  communicationStyle String?
  dynamics           String?
  traditions         String?
  historicalContext  String?
  facets             Json?
  providerName       String?
  model              String?
  isMock             Boolean  @default(false)
  inputHash          String?
  generatedAt        DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum RelationshipType {
  RIVALRY
  FRIENDSHIP
  ALLIANCE
  ANTAGONISM
  MIXED
  NEUTRAL
}

/// A private, admin-only narrative summary of the relationship between two
/// managers (rivalry, friendship, running feuds/jokes), synthesized from chat
/// evidence + head-to-head history. Pair is stored canonically with
/// managerAId < managerBId (string compare) so each pair has exactly one row.
model ManagerRelationship {
  id               String           @id @default(cuid())
  managerAId       String
  managerA         Manager          @relation("RelationshipManagerA", fields: [managerAId], references: [id])
  managerBId       String
  managerB         Manager          @relation("RelationshipManagerB", fields: [managerBId], references: [id])
  relationshipType RelationshipType @default(MIXED)
  summary          String
  /// 0-1 how strong/active the relationship is (drives how heavily content leans on it).
  intensity        Float            @default(0.5)
  privacyStatus    PrivacyStatus    @default(PRIVATE)
  facets           Json?
  providerName     String?
  model            String?
  isMock           Boolean          @default(false)
  generatedAt      DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@unique([managerAId, managerBId])
  @@index([managerBId])
}
